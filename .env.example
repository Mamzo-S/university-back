# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_URL=jdbc:postgresql://localhost:5432/universite_db
DB_USERNAME=postgres
DB_PASSWORD=Emilie06
DB_DRIVER=org.postgresql.Driver

# ============================================
# APPLICATION
# ============================================
SERVER_PORT=8080
APP_NAME=Université Cheikh Hamidou KANE

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=bXlzZWNyZXRrZXlteXNlY3JldGtleW15c2VjcmV0a2V5
JWT_EXPIRATION=86400000

# ============================================
# FILE UPLOAD
# ============================================
FILE_UPLOAD_DIR=uploads
MAX_FILE_SIZE=10MB

# ============================================
# LOGGING
# ============================================
LOGGING_LEVEL=INFO
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_FORMAT_SQL=true

# ============================================
# CORS (optionnel, à configurer en production)
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ============================================
# SWAGGER/OPENAPI
# ============================================
SPRINGDOC_OPENAPI_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true
